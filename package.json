{
  "name": "poc-strands-agents-ts",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "start": "npm run build && dotenvx run -f .env -- node dist/index.js",
    "mcp:http": "dotenvx run -f .env -- tsx src/mcp-server-http.ts"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-agentcore": "latest",
    "@dotenvx/dotenvx": "^1.61.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@strands-agents/sdk": "latest",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
