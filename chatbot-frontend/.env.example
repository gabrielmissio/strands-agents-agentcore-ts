# ── Agent Mode ────────────────────────────────────────────────────────
# "bff"    → calls the BFF proxy
# "direct" → calls AgentCore directly
VITE_AGENT_MODE=bff

# Cognito sign-in is still required by the current frontend app in both modes.

# ── BFF Mode Config ──────────────────────────────────────────────────
VITE_API_URL=/api

# ── Direct Mode Config (Cognito + AgentCore) ─────────────────────────
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_USER_POOL_CLIENT_ID=
VITE_COGNITO_IDENTITY_POOL_ID=
VITE_COGNITO_REGION=us-east-1
VITE_AGENT_RUNTIME_ARN=
VITE_AGENT_ENDPOINT_NAME=DEFAULT
VITE_AWS_REGION=us-east-1
# Optional override (auto-constructed from region if omitted)
# VITE_AGENTCORE_URL=https://bedrock-agentcore.us-east-1.amazonaws.com
