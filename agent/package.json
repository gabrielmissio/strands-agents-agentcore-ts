{
  "name": "caveman-agent",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "npm run build && dotenvx run -f .env -- node dist/index.js",
    "mcp:http": "dotenvx run -f .env -- tsx src/mcp-servers/http-mcp-server.ts",
    "invoke:bedrock": "dotenvx run -f .env -- tsx src/invoke.ts"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-agentcore": "latest",
    "@dotenvx/dotenvx": "^1.61.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@strands-agents/sdk": "latest",
    "@x402/axios": "^2.10.0",
    "@x402/evm": "^2.10.0",
    "amazon-cognito-identity-js": "^6.3.16",
    "axios": "^1.15.0",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "viem": "^2.48.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
